{
  "dataRoles": [
    {
      "displayName": "Category",
      "name": "category",
      "description": "Section grouping \u2014 each distinct value creates a slicer section",
      "kind": "Grouping"
    },
    {
      "displayName": "Label",
      "name": "label",
      "description": "Display text for each item within a section",
      "kind": "Grouping"
    },
    {
      "displayName": "Value",
      "name": "value",
      "description": "Filter target as Table.Column (e.g. DimDate.Period). Leave empty for static display.",
      "kind": "Grouping"
    },
    {
      "displayName": "Sort order",
      "name": "sortOrder",
      "description": "Numeric sort within each section",
      "kind": "Measure"
    },
    {
      "displayName": "Display mode",
      "name": "displayMode",
      "description": "Render style per section: Chips or Dropdown. Overrides formatting panel default.",
      "kind": "Grouping"
    },
    {
      "displayName": "Selection mode",
      "name": "selectionMode",
      "description": "Selection behaviour per section: Single or Multi. Overrides formatting panel default.",
      "kind": "Grouping"
    },
    {
      "displayName": "Short label",
      "name": "shortLabel",
      "description": "Secondary text shown when item is selected (e.g. date range). Optional.",
      "kind": "Grouping"
    },
    {
      "displayName": "Default value",
      "name": "defaultValue",
      "description": "Label of the item to auto-select on load. Use a measure per page for dynamic defaults.",
      "kind": "Grouping"
    }
  ],
  "objects": {
    "general": {
      "displayName": "General",
      "properties": {
        "filter": {
          "type": {
            "filter": {
              "selfFilterEnabled": false
            }
          }
        }
      }
    },
    "slicerBar": {
      "properties": {
        "backgroundColor": {
          "type": {
            "fill": {
              "solid": {
                "color": true
              }
            }
          },
          "displayName": "Background Color"
        },
        "borderColor": {
          "type": {
            "fill": {
              "solid": {
                "color": true
              }
            }
          },
          "displayName": "Border Color"
        },
        "labelColor": {
          "type": {
            "fill": {
              "solid": {
                "color": true
              }
            }
          },
          "displayName": "Label Color"
        },
        "labelFontSize": {
          "type": {
            "numeric": true
          },
          "displayName": "Label Font Size"
        },
        "chipColor": {
          "type": {
            "fill": {
              "solid": {
                "color": true
              }
            }
          },
          "displayName": "Chip Color"
        },
        "chipTextColor": {
          "type": {
            "fill": {
              "solid": {
                "color": true
              }
            }
          },
          "displayName": "Chip Text Color"
        },
        "defaultDisplayMode": {
          "type": {
            "enumeration": [
              {
                "displayName": "Auto",
                "value": "auto"
              },
              {
                "displayName": "Chips",
                "value": "chips"
              },
              {
                "displayName": "Dropdown",
                "value": "dropdown"
              }
            ]
          },
          "displayName": "Default Display Mode"
        },
        "defaultSelectionMode": {
          "type": {
            "enumeration": [
              {
                "displayName": "Single",
                "value": "single"
              },
              {
                "displayName": "Multi",
                "value": "multi"
              }
            ]
          },
          "displayName": "Default Selection Mode"
        },
        "maxVisibleChips": {
          "type": {
            "numeric": true
          },
          "displayName": "Max Visible Chips"
        },
        "maxVisibleSections": {
          "type": {
            "numeric": true
          },
          "displayName": "Max Visible Sections"
        },
        "fanDirection": {
          "type": {
            "enumeration": [
              {
                "displayName": "Auto",
                "value": "auto"
              },
              {
                "displayName": "Fan Right",
                "value": "right"
              },
              {
                "displayName": "Fan Left",
                "value": "left"
              },
              {
                "displayName": "Fan Up",
                "value": "up"
              },
              {
                "displayName": "Fan Down",
                "value": "down"
              }
            ]
          },
          "displayName": "Fan Direction"
        }
      },
      "displayName": "Slicer Bar"
    },
    "sectionOverride": {
      "properties": {
        "displayMode": {
          "type": {
            "enumeration": [
              {
                "displayName": "Auto",
                "value": "auto"
              },
              {
                "displayName": "Chips",
                "value": "chips"
              },
              {
                "displayName": "Dropdown",
                "value": "dropdown"
              }
            ]
          },
          "displayName": "Display Mode"
        },
        "selectionMode": {
          "type": {
            "enumeration": [
              {
                "displayName": "Single",
                "value": "single"
              },
              {
                "displayName": "Multi",
                "value": "multi"
              }
            ]
          },
          "displayName": "Selection Mode"
        },
        "defaultValue": {
          "type": {
            "text": true
          },
          "displayName": "Default Value"
        }
      },
      "displayName": "Section Override"
    }
  },
  "dataViewMappings": [
    {
      "categorical": {
        "categories": {
          "select": [
            {
              "for": {
                "in": "category"
              }
            },
            {
              "for": {
                "in": "label"
              }
            },
            {
              "for": {
                "in": "value"
              }
            },
            {
              "for": {
                "in": "sortOrder"
              }
            },
            {
              "for": {
                "in": "displayMode"
              }
            },
            {
              "for": {
                "in": "selectionMode"
              }
            },
            {
              "for": {
                "in": "shortLabel"
              }
            },
            {
              "for": {
                "in": "defaultValue"
              }
            }
          ],
          "dataReductionAlgorithm": {
            "top": {
              "count": 30000
            }
          }
        }
      }
    }
  ],
  "privileges": [
    {
      "name": "LocalStorage",
      "essential": false
    }
  ],
  "supportsHighlight": true,
  "supportsKeyboardFocus": true,
  "supportsLandingPage": true,
  "supportsEmptyDataView": true,
  "supportsMultiVisualSelection": true,
  "tooltips": {
    "supportedTypes": {
      "default": true,
      "canvas": true
    }
  }
}